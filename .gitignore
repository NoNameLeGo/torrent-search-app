# 依赖（已在项目内安装，不入库）
node_modules/

# 环境变量 / 本地配置（忽略所有 .env 变体，但保留示例模板）
.env
.env.*
!.env.example
*.local

# 密钥 / 证书（防止误提交导致泄露）
*.pem
*.key
*.crt
*.cer
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# 日志
*.log
npm-debug.log*

# 系统 / 编辑器
.DS_Store
Thumbs.db
.idea/
.vscode/

# 构建缓存（重定向到项目目录，避免占用 C 盘）
.cache/

# 本地工具数据（本机/每用户，不入库）
.workbuddy/

# Torznab 索引器配置（含 API Key，本地数据，禁止入库）
data/

# 打包产物（portable 版约 360MB，不入库）
dist/

# Tauri 本地构建缓存（Rust target 可达数 GB；正式包由 GitHub Actions 从 feat/tauri 打，本地无需保留）
src-tauri/target/
