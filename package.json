{
  "name": "torrent-search-app",
  "version": "0.1.0-beta",
  "private": true,
  "description": "Desktop BT torrent meta-search web app aggregating multiple engines (1337x, TPB, NYAA).",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "set ELECTRON_CACHE=.cache\\electron&& electron .",
    "dist": "set ELECTRON_CACHE=.cache\\electron&& set ELECTRON_BUILDER_CACHE=.cache\\builder&& electron-builder --publish=onTag",
    "build:portable": "node scripts/build-portable.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "express": "^4.21.0"
  },
  "build": {
    "appId": "com.torrentsearch.app",
    "productName": "BT 聚合搜索",
    "files": [
      "server.js",
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "artifactName": "BT聚合搜索-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "NoNameLeGo",
      "repo": "torrent-search-app"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
